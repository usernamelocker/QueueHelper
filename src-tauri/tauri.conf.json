{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Queue Helper",
  "version": "0.1.2-beta",
  "identifier": "com.admin.queue-helper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Queue Helper",
        "width": 1000,
        "height": 715,
        "minWidth": 1000,
        "minHeight": 715,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzODdFNDBGQTE4NjBCMjIKUldRaUM0YWhEK1NIVThUMWEyMjFxSVQ5WDFvd09KVkZWenpXVVRoODhoWE1hbFlCLzhmMGU2ZEUK",
      "endpoints": [
        "https://raw.githubusercontent.com/usernamelocker/QueueHelper/master/update.json"
      ]
    }
  }
}
